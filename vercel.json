{
  "rewrites": [
    {
      "source": "/auth/mercadolibre",
      "destination": "/api/auth/mercadolibre"
    }
  ],
  "headers": [
    {
      "source": "/uploads.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron?task=sync-master-embarques",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron?task=actualizar-fill-rates",
      "schedule": "30 12 * * *"
    }
  ]
}
